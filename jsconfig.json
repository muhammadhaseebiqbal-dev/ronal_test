{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "jsx": "react-jsx"
    },
    "include": [
        "src/**/*",
        "*.js",
        "*.jsx"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}